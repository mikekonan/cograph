{
  "name": "cograph-web",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Frontend for Cograph — a self-hosted tool that turns git repositories into browsable knowledge bases (auto-generated docs, RAG chat, code-graph explorer).",
  "homepage": "https://github.com/mikekonan/cograph",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikekonan/cograph.git",
    "directory": "web"
  },
  "bugs": {
    "url": "https://github.com/mikekonan/cograph/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:real": "VITE_USE_MOCKS=false vite",
    "dev:e2e": "npm run msw:init && vite --host 127.0.0.1 --port 4173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc -b --noEmit",
    "msw:init": "msw init public/ --save",
    "test": "vitest run",
    "e2e": "npm run msw:init && playwright test"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^9.1.0",
    "react-router": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0-beta.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^29.0.2",
    "msw": "^2.6.4",
    "tailwindcss": "^4.0.0-beta.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
